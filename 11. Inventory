import java.util.HashMap;
import java.util.Map;

public class Inventory {

    private final Map<String, Product> products;

    public Inventory() {
        this.products = new HashMap<>();
    }

    public void addProduct(Product product) {
        products.put(product.getProductId(), product);
    }

    public boolean checkAvailability(String productId, int requestedQuantity) {
        Product product = products.get(productId);
        if (product == null) {
            System.out.println("Product not found: " + productId);
            return false;
        }
        return product.getStock() >= requestedQuantity;
    }

    public boolean updateQuantity(String productId, int quantitySold) {
        Product product = products.get(productId);
        if (product == null) {
            System.out.println("Product not found: " + productId);
            return false;
        }
        if (product.getStock() < quantitySold) {
            System.out.println("Insufficient stock for: " + product.getName());
            return false;
        }
        product.updateStock(quantitySold);
        System.out.println("Stock updated for " + product.getName() +
                           ". Remaining stock: " + product.getStock());
        return true;
    }

    public void displayInventory() {
        System.out.println("\nCurrent Inventory:");
        System.out.println("─".repeat(40));
        for (Product product : products.values()) {
            System.out.printf("%-20s | Stock: %d%n",
                              product.getName(), product.getStock());
        }
    }
}
